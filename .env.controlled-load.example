# Controlled Load Layer 1 runtime example.
# Copy this file to .env.controlled-load and edit local values.
# Do not commit .env.controlled-load.

RPC_URL=http://host.containers.internal:8899
PROM_URL=http://host.containers.internal:9464

KEYPAIR_PATH_HOST=/absolute/path/to/payer.json
KEYPAIR_PATH_CONTAINER=/run/secrets/solana/payer.json

LOADGEN_LISTEN=0.0.0.0:7070
LOADGEN_URL=http://loadgen2:7070

WORKERS=16
INFLIGHT=128
LAMBDA_INITIAL=1
BURST=1

LEVELS_STR=1 2 5 10
HOLD=30
SAMPLE=2
WARMUP=0

EXPERIMENT_ID=controlled-load-local-smoke
